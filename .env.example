# 生产环境务必修改
JWT_SECRET=请替换为至少32位随机字符串
PORT=3080
DATABASE_PATH=./data/app.db

# 站点标识（登录页展示，如 leadsales）
SITE_SLUG=leadsales

# 正式访问地址（绑定域名后填写，如 https://leadsales.yourcompany.com）
PUBLIC_SITE_URL=

# --- 移卡邮件自动导入（可选）---
# 随机长字符串，供 scripts/email-import 调用 POST /api/import/auto
IMPORT_API_KEY=
# QQ 邮箱完整地址 + 授权码（设置 → 账户 → POP3/IMAP/SMTP → 开启服务）
QQ_IMAP_USER=your@qq.com
QQ_IMAP_PASS=
# 发通知邮件；留空则与 QQ_IMAP_USER 相同
QQ_SMTP_USER=
QQ_SMTP_PASS=
# 导入结果通知收件人（你的邮箱）
EMAIL_IMPORT_NOTIFY_TO=your@qq.com
# 容器内调用看板地址，默认即可
DASHBOARD_IMPORT_URL=http://127.0.0.1:3080
