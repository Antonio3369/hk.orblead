{
  "name": "merchant-transaction-agent",
  "version": "2.0.0",
  "description": "商户交易变化监控与预警 — 销售外网可用",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "cross-env USE_VITE=1 tsx watch server/index.ts",
    "build": "vite build && tsc -p tsconfig.server.json",
    "start": "node dist-server/index.js",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.server.json --noEmit",
    "db:seed": "tsx server/seed.ts",
    "sandbox": "tsx tools/sandbox-sales-gap.ts",
    "sandbox:open": "bash scripts/sandbox-dev.sh",
    "pack:deploy": "bash scripts/deploy-pack.sh",
    "pack:frontend": "bash scripts/deploy-frontend.sh",
    "email-import": "tsx server/emailImport/run.ts"
  },
  "dependencies": {
    "bcryptjs": "^3.0.2",
    "cors": "^2.8.5",
    "express": "^5.1.0",
    "imapflow": "^1.4.3",
    "jsonwebtoken": "^9.0.2",
    "mailparser": "^3.9.12",
    "multer": "^2.0.1",
    "nodemailer": "^9.0.3",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "recharts": "^2.15.3",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.18",
    "@types/express": "^5.0.2",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.15.3",
    "@types/nodemailer": "^8.0.1",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^4.4.1",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vite": "^6.3.5"
  }
}
